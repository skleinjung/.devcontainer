#!/usr/bin/env bash
set -euo pipefail

LOG_DIR="/workspace/.devcontainer/logs"
mkdir -p "$LOG_DIR"
exec > >(tee "$LOG_DIR/container.log") 2>&1

echo "[post-attach] Started."

# Drop-ins run best-effort: a failing one is logged and skipped so it can't take
# down the rest of the attach.
status=0
for script in /usr/local/bin/post-attach.d/*.sh; do
  [ -f "$script" ] || continue
  echo "[post-attach] Running $(basename "$script")..." >&2
  rc=0
  bash "$script" || rc=$?
  if [ "$rc" -ne 0 ]; then
    echo "[post-attach] $(basename "$script") failed (exit $rc); continuing." >&2
    status=1
  fi
done

echo "[post-attach] Complete."
exit "$status"
