{
  "containerEnv": {
    "NODE_OPTIONS": "--experimental-transform-types --no-warnings=ExperimentalWarning",
    "PW_CHROMIUM_SANDBOX": "0",
    "VSCODE_AGENT_FOLDER": "/vscode",
    // the workspace image sets AWS_SHARED_CREDENTIALS_FILE=/creds/aws/credentials, so the
    // workspace reads the vended AWS creds with no config here. (Don't set AWS_PROFILE to an
    // SSO profile — it would override the shelf [default].)
    //
    // This workspace's primary GitHub org — base's devcred/git/gh shims use it when no repo
    // context pins one. Must match a vended org (a github-app grant in creds/vend.yaml).
    "GH_DEFAULT_ORG": "skleinjung",
    // Default region for AWS CLI/SDK calls — the vended credentials file carries no region.
    "AWS_REGION": "us-east-1",
    // base scrubs SSH_AUTH_SOCK from interactive shells by default; opt out — we use the
    // forwarded FIDO/YubiKey agent (hardware-touch-gated) for SSH-remote git.
    "SCRUB_SSH_AUTH_SOCK_ENABLED": "false",
    // Make Claude Code fetch the plugin marketplace over HTTPS instead of git@github.com
    // (ssh), so it rides the App-token auth instead of prompting a hardware touch on startup.
    "CLAUDE_CODE_PLUGIN_PREFER_HTTPS": "1",
    // Point the Docker CLI at the external agent-domain engine over SSH (twin-digital/opus#164)
    // — no local daemon, no host socket. build/pull/run happen on the remote host; the SSH
    // transport reuses the forwarded agent and connects as the container user. Short hostname
    // (not IP) so it tracks DHCP.
    "DOCKER_HOST": "ssh://prod-development-docker"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "dev.containers.dockerCredentialHelper": false,
        // Don't inject GIT_ASKPASS: it forwards credential prompts to VS Code, which can hand
        // a process the human's broad VS Code GitHub OAuth token — far more than the scoped
        // shelf tokens. git/gh are unaffected (they use base's devcred credential helper).
        "git.useIntegratedAskPass": false,
        // Don't inject VS Code's host-credential-proxy helper into the container's gitconfig
        // (a separate path that bridges the HOST's stored git credentials in). Neither this
        // nor useIntegratedAskPass alone is sufficient — see vscode-remote-release#4426.
        "dev.containers.gitCredentialHelperConfigLocation": "none",
        // Don't copy the host's ~/.gitconfig / .git-credentials into the container.
        "dev.containers.copyGitConfig": false,
        // Don't register VS Code as the terminal Git editor — its git-editor IPC socket is
        // reaped (entrypoint), and git uses nano (core.editor, set by base) instead.
        "git.terminalGitEditor": false,
        "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
      }
    }
  },
  "dockerComposeFile": ["docker-compose.yml"],
  // The toolchains (aws-cli, github-cli, node/nvm, python, terraform) come baked into the
  // `workspace` image, so there's no `features` block. Only the Docker CLI is installed (in
  // this project's Dockerfile) — no daemon and no host socket, which would give agents
  // root-equivalent reach onto the host. Docker workloads run on an external agent-domain
  // engine via DOCKER_HOST above (twin-digital/opus#164).
  "forwardPorts": [3001, 7470],
  "portsAttributes": {},
  "init": true,
  "initializeCommand": ".devcontainer/scripts/host/initialize.sh",
  "name": "Workspace",
  // false so VS Code keeps the compose entrypoint (base's reap-vscode-sockets) instead of
  // replacing it with its own keep-alive.
  "overrideCommand": false,
  "postAttachCommand": "/usr/local/bin/post-attach",
  "postCreateCommand": "/usr/local/bin/post-create",
  "remoteEnv": {
    // Blank VS Code's host-reaching channels for every process VS Code spawns (terminals AND
    // an agent's non-interactive `bash -c`). base's shell scrub additionally covers integrated
    // terminals, where VS Code re-injects some of these on top of remoteEnv.
    //   GIT_ASKPASS / VSCODE_GIT_* : VS Code's askpass → the human's broad GitHub OAuth token.
    //   VSCODE_IPC_HOOK_CLI : the `code` CLI channel. BROWSER / GPG_AGENT_INFO : host launch/GPG.
    // SSH_AUTH_SOCK is intentionally NOT blanked here (the forwarded FIDO agent); base's
    // default shell scrub of it is opted out via SCRUB_SSH_AUTH_SOCK_ENABLED above.
    "GIT_ASKPASS": "",
    "VSCODE_GIT_IPC_HANDLE": "",
    "VSCODE_GIT_ASKPASS_MAIN": "",
    "VSCODE_GIT_ASKPASS_NODE": "",
    "VSCODE_GIT_ASKPASS_EXTRA_ARGS": "",
    "VSCODE_IPC_HOOK_CLI": "",
    "BROWSER": "",
    "GPG_AGENT_INFO": ""
  },
  "remoteUser": "${localEnv:USER}",
  "service": "workspace",
  "workspaceFolder": "/workspace"
}
